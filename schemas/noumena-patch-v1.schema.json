{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Noumena Patch v1",
  "type": "object",
  "required": ["schema", "base", "author", "intent", "ops"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "noumena.patch.v1" },
    "clientPatchId": { "type": "string", "minLength": 1 },
    "base": {
      "type": "object",
      "required": ["revision"],
      "additionalProperties": true,
      "properties": {
        "revision": { "type": "string", "minLength": 1 },
        "logicalVersion": { "type": "integer", "minimum": 0 },
        "blockHashes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "author": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": { "enum": ["agent", "human"] },
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "intent": { "type": "string" },
    "ops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["op", "target"],
        "additionalProperties": true,
        "properties": {
          "op": {
            "enum": [
              "append_evidence",
              "append_note",
              "append_agent_event",
              "set_status",
              "set_metadata",
              "propose_summary"
            ]
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "role": { "type": "string" },
              "blockId": { "type": "string" }
            },
            "anyOf": [
              { "required": ["role"] },
              { "required": ["blockId"] }
            ]
          }
        }
      }
    }
  }
}
